<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Configuracoes basicas da pagina e importacao do CSS. -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %></title>
  <link rel="stylesheet" href="/static/style.css?v=10">
</head>
<body>
  <% /* A classe do main muda quando a tela atual e uma TV publica ou uma tela operacional. */ %>
  <main class="function-page <%= tela === 'tvPublica' || tela === 'tvResultado' ? 'tv-public-page' : '' %> <%= tela === 'operador' || tela === 'loginCoordenador' || tela === 'painelCoordenador' || tela === 'modoTv' || tela === 'fechamento' || tela === 'confirmacaoFechamento' || tela === 'resultadoOficial' || tela === 'publicarResultado' || tela === 'detalheEquipe' || tela === 'filtroAtletasEquipe' || tela === 'equipe' || tela === 'atleta' || tela === 'esteira' || tela === 'checkpoint' || tela === 'encerramento' ? 'operator-screen' : '' %>" aria-labelledby="page-title">
    <% /* O frame tambem muda quando o conteudo deve ocupar a tela inteira da TV. */ %>
    <section class="function-frame <%= tela === 'tvPublica' || tela === 'tvResultado' ? 'tv-frame' : '' %>">
      <% /* Nota: esta view renderiza mais de uma etapa do fluxo usando a variavel "tela". */ %>
      <% if (tela === 'operador' || tela === 'loginCoordenador') { %>
        <% /* Link para voltar ao inicio do fluxo. */ %>
        <a href="/" class="back-link">VOLTAR</a>
      <% } %>

      <% if (tela === 'painelCoordenador') { %>
        <% /* Volta para a autenticacao do coordenador(a). */ %>
        <form action="/voltar-login-coordenador" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'modoTv') { %>
        <% /* Volta para a visao geral da coordenacao. */ %>
        <form action="/voltar-painel-coordenador" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'fechamento') { %>
        <% /* Volta do fechamento para a visao geral da coordenacao. */ %>
        <form action="/voltar-painel-coordenador" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'confirmacaoFechamento') { %>
        <% /* Volta da confirmacao para a revisao de fechamento. */ %>
        <form action="/voltar-fechamento" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'resultadoOficial') { %>
        <% /* Volta do resultado oficial para a revisao de fechamento. */ %>
        <form action="/voltar-fechamento" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'publicarResultado') { %>
        <% /* Volta da publicacao para o resultado oficial privado. */ %>
        <form action="/voltar-resultado-oficial" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'detalheEquipe') { %>
        <% /* Volta para a visao geral da coordenacao. */ %>
        <form action="/voltar-painel-coordenador" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'filtroAtletasEquipe') { %>
        <% /* Volta para os detalhes gerais da equipe. */ %>
        <form action="/detalhes-equipe" method="post" class="back-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <input type="hidden" name="equipe" value="<%= equipePainel.nome %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'equipe') { %>
        <% /* Volta para a etapa anterior mantendo o operador selecionado. */ %>
        <form action="/voltar-operador" method="post" class="back-form">
          <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'atleta') { %>
        <% /* Volta para a selecao de equipe mantendo operador e equipe selecionados. */ %>
        <form action="/voltar-equipe" method="post" class="back-form">
          <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
          <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'esteira') { %>
        <% /* Volta para a selecao de atleta mantendo operador, equipe e atleta selecionados. */ %>
        <form action="/voltar-atleta" method="post" class="back-form">
          <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
          <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
          <input type="hidden" name="atleta" value="<%= atletaSelecionado %>">
          <button type="submit" class="back-link">VOLTAR</button>
        </form>
      <% } %>

      <% if (tela === 'equipe' || tela === 'atleta' || tela === 'esteira') { %>
        <% /* Mostra qual operador esta autenticado nesta etapa. */ %>
        <div class="selected-user">
          <span>OPERADOR(A)</span>
          <strong><%= operadorSelecionado %></strong>
        </div>
      <% } %>

      <%
        /* Mapa central que liga cada tela ao texto da etapa exibida no topo. */
        const etapas = {
          funcao: 'ETAPA 00 · ACESSO',
          operador: 'ETAPA 01 · OPERADOR(A)',
          loginCoordenador: 'ETAPA 01 · AUTENTICAÇÃO',
          painelCoordenador: 'ETAPA 02 · VISÃO GERAL',
          modoTv: 'RAMO A · EXIBIÇÃO',
          fechamento: 'RAMO B · FECHAMENTO',
          confirmacaoFechamento: 'RAMO B · CONFIRMAÇÃO',
          resultadoOficial: 'RAMO B · RESULTADO',
          publicarResultado: 'RAMO B · RESULTADO',
          detalheEquipe: 'ETAPA 03 · EQUIPE',
          filtroAtletasEquipe: 'ETAPA 03.1 · FILTRO',
          equipe: 'ETAPA 02 · EQUIPE',
          atleta: 'ETAPA 03 · ATLETA',
          esteira: 'ETAPA 04 · TURNO',
          checkpoint: 'ETAPA 05 · CHECKPOINT',
          encerramento: 'ETAPA 06 · ENCERRAMENTO'
        };
      %>

      <% if (tela !== 'tvPublica' && tela !== 'tvResultado') { %>
        <% /* Etiqueta da etapa atual, centralizada em todas as telas. */ %>
        <p class="step-label"><%= etapas[tela] || 'ETAPA' %></p>

        <% /* Titulo muda conforme a tela enviada pelo server.ts. */ %>
        <h1 id="page-title"><%= titulo %></h1>
      <% } %>

      <% if (tela === 'funcao') { %>
        <% /* Nota: bloco responsavel pela selecao de funcao inicial. */ %>
        <p class="operator-description">
          Escolha como você irá acessar o sistema.
        </p>

        <div class="function-options" aria-label="Seleção de função">
          <% funcoes.forEach((funcao) => { %>
            <% /* Cada formulario envia uma funcao escolhida para o servidor. */ %>
            <form action="/selecionar-funcao" method="post" class="function-form">
              <input type="hidden" name="funcao" value="<%= funcao.valor %>">
              <button type="submit" class="function-card">
                <span class="function-icon" aria-hidden="true"><%= funcao.nome.slice(0, 2) %></span>
                <span class="function-name"><%= funcao.nome %></span>
                <span class="operator-radio" aria-hidden="true"></span>
              </button>
            </form>
          <% }) %>
        </div>
      <% } %>

      <% if (tela === 'loginCoordenador') { %>
        <% /* Nota: autenticacao visual do coordenador(a) antes das telas administrativas. */ %>
        <p class="operator-description">
          Entre para administrar a operação.
        </p>

        <span class="login-badge"><%= perfilLogin === 'administrador_geral' ? 'ADMINISTRADOR(A) GERAL' : 'COORDENADOR(A)' %></span>
        <p class="login-helper">Ações administrativas ficam registradas.</p>

        <form action="/login-coordenador" method="post" class="login-form" id="coordinatorLoginForm">
          <input type="hidden" name="perfilUsuario" value="<%= perfilLogin || perfilUsuario || 'coordenador' %>">
          <label class="field-group" for="coordenadorNome">
            <span class="field-label">NOME DO USUÁRIO *</span>
            <input id="coordenadorNome" name="coordenador" class="checkpoint-input" type="text" placeholder="Digite o nome" required>
          </label>

          <label class="field-group" for="coordenadorSenha">
            <span class="field-label">SENHA *</span>
            <input id="coordenadorSenha" name="senha" class="checkpoint-input" type="password" placeholder="Digite sua senha" required>
          </label>

          <section class="permission-card">
            <strong>PERMISSÕES</strong>
            <span><%= perfilLogin === 'administrador_geral' ? 'Acesso completo, pausa, retomada e encerramento' : 'Auditoria, correção, TV e exportação' %></span>
          </section>

          <% if (typeof loginMensagem !== 'undefined') { %>
            <p class="checkpoint-message success"><%= loginMensagem %></p>
          <% } %>

          <button type="submit" class="continue-button" id="coordinatorLoginButton" disabled>
            Preencha os campos para entrar
          </button>
        </form>

        <script>
          (() => {
            // Busca o formulario de login no HTML.
            const form = document.getElementById('coordinatorLoginForm');
            // Busca o botao de login que sera ativado/desativado.
            const button = document.getElementById('coordinatorLoginButton');
            // Pega todos os campos obrigatorios dentro do formulario.
            const fields = Array.from(form.querySelectorAll('[required]'));

            // Atualiza o estado do botao conforme os campos forem preenchidos.
            const updateButton = () => {
              // Verifica se todos os campos obrigatorios possuem algum texto.
              const ready = fields.every((field) => field.value.trim());
              // Desativa o botao quando ainda falta algum campo.
              button.disabled = !ready;
              // Troca o texto do botao para orientar o usuario.
              button.textContent = ready ? 'Entrar no painel' : 'Preencha os campos para entrar';
            };

            // Escuta digitacao em cada campo obrigatorio.
            fields.forEach((field) => {
              field.addEventListener('input', updateButton);
            });

            // Roda uma primeira vez para deixar o botao correto ao carregar a tela.
            updateButton();
          })();
        </script>
      <% } %>

      <% if (tela === 'operador') { %>
        <% /* Nota: bloco responsavel pela selecao de qual operador esta usando o sistema. */ %>
        <p class="operator-description">
          Escolha quem está operando o sistema neste momento.
        </p>

        <p class="operator-list-title">OPERADORES(AS) CADASTRADOS(AS)</p>

        <div class="operator-list" aria-label="Seleção de operador">
          <% operadores.forEach((operador) => { %>
            <% const selecionado = typeof operadorSelecionado !== 'undefined' && operadorSelecionado === operador.nome; %>
            <% /* Cada formulario envia o operador escolhido para o servidor. */ %>
            <form action="/selecionar-operador" method="post" class="function-form">
              <input type="hidden" name="operador" value="<%= operador.nome %>">
              <button type="submit" class="operator-row <%= selecionado ? 'is-selected' : '' %>">
                <span class="operator-photo" aria-hidden="true"><%= operador.iniciais %></span>
                <span class="operator-name"><%= operador.nome %></span>
                <% if (selecionado) { %>
                  <span class="selected-badge">SELECIONADO</span>
                <% } %>
                <span class="operator-radio" aria-hidden="true"></span>
              </button>
            </form>
          <% }) %>
        </div>

        <% if (typeof operadorSelecionado !== 'undefined') { %>
          <% /* Botao avanca para a selecao de equipe mantendo o operador escolhido. */ %>
          <form action="/continuar-operador" method="post" class="continue-form">
            <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
            <button type="submit" class="continue-button">
              Continuar como <%= operadorSelecionado %>
            </button>
          </form>
          <p class="operator-helper">Os checkpoints serão registrados em seu nome.</p>
        <% } %>
      <% } %>

      <% if (tela === 'painelCoordenador') { %>
        <% /* Nota: visao geral administrativa depois do login do coordenador(a). */ %>
        <p class="operator-description">
          Acompanhe a operação em tempo real.
        </p>

        <section class="panel-progress">
          <strong>08h 42min de 24h</strong>
          <span><%= estadoProva.status === 'finalizada' ? 'FINALIZADA' : estadoProva.status === 'pausada' ? 'PAUSADA' : 'EM ANDAMENTO' %></span>
        </section>

        <% if (typeof painelMensagem !== 'undefined') { %>
          <p class="checkpoint-message success"><%= painelMensagem %></p>
        <% } %>

        <section class="panel-metrics" aria-label="Resumo da prova">
          <article>
            <strong>TURNOS ATIVOS</strong>
            <span>2</span>
          </article>
          <article>
            <strong>CHECKPOINTS</strong>
            <span>186</span>
          </article>
          <article>
            <strong>ALERTAS</strong>
            <span>2</span>
          </article>
        </section>

        <p class="operator-list-title">EQUIPES</p>

        <div class="panel-team-list" aria-label="Equipes monitoradas">
          <% equipesPainel.forEach((equipe) => { %>
            <article class="panel-team-card">
              <span class="status-dot" aria-hidden="true"></span>
              <div>
                <strong><%= equipe.nome %></strong>
                <small><%= equipe.km %> · <%= equipe.atleta %></small>
              </div>
              <form action="/detalhes-equipe" method="post" class="details-form">
                <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
                <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
                <input type="hidden" name="equipe" value="<%= equipe.nome %>">
                <button type="submit">DETALHES</button>
              </form>
            </article>
          <% }) %>
        </div>

        <p class="operator-list-title">AÇÕES DA COORDENAÇÃO</p>

        <section class="panel-actions">
          <button type="button" class="is-active">Auditoria</button>
          <form action="/modo-tv" method="post">
            <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
            <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
            <button type="submit">Modo TV</button>
          </form>
          <a href="/exportar-dados?perfilUsuario=<%= perfilUsuario %>" class="panel-action-link">Exportar CSV</a>
          <% if (pode('pausar_prova') && estadoProva.status === 'em_andamento') { %>
            <form action="/pausar-prova" method="post">
              <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
              <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
              <button type="submit">Pausar prova</button>
            </form>
          <% } %>
          <% if (pode('retomar_prova') && estadoProva.status === 'pausada') { %>
            <form action="/retomar-prova" method="post">
              <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
              <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
              <button type="submit">Retomar prova</button>
            </form>
          <% } %>
          <% if (pode('finalizar_prova')) { %>
            <form action="/fechamento" method="post">
              <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
              <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
              <button type="submit">Fechamento</button>
            </form>
          <% } %>
        </section>
      <% } %>

      <% if (tela === 'modoTv') { %>
        <% /* Nota: controle do placar externo. A tela publica fica em /tv. */ %>
        <p class="operator-description">
          Controle o placar público somente leitura.
        </p>

        <p class="operator-list-title">ESTADO ATUAL</p>

        <section class="tv-control-card is-active" id="tvControlCard">
          <div>
            <strong>PLACAR EXTERNO</strong>
            <span>Atualização automática dos dados válidos</span>
          </div>
          <span class="tv-active-pill" id="tvStateLabel">ATIVO</span>
          <button type="button" class="toggle-switch" id="tvToggle" aria-pressed="true" aria-label="Ativar ou desativar Modo TV"></button>
        </section>

        <p class="operator-list-title">INFORMAÇÕES VISÍVEIS</p>

        <section class="visible-info-list" aria-label="Informações visíveis no placar">
          <label class="check-option">
            <input type="checkbox" checked>
            <span>Distância total por equipe</span>
          </label>
          <label class="check-option">
            <input type="checkbox" checked>
            <span>Diferença entre equipes</span>
          </label>
          <label class="check-option">
            <input type="checkbox" checked>
            <span>Tempo restante da prova</span>
          </label>
          <label class="check-option">
            <input type="checkbox">
            <span>Nome do atleta atual</span>
          </label>
        </section>

        <p class="public-note">A tela pública não permite edição.</p>

        <a href="/tv" target="_blank" rel="noopener" class="continue-button external-screen-button" id="externalScreenButton">
          Abrir tela externa
        </a>

        <script>
          (() => {
            // Card principal do controle do Modo TV.
            const card = document.getElementById('tvControlCard');
            // Botao estilo chave liga/desliga.
            const toggle = document.getElementById('tvToggle');
            // Texto que mostra ATIVO ou INATIVO.
            const label = document.getElementById('tvStateLabel');
            // Link que abre a tela externa da TV.
            const externalButton = document.getElementById('externalScreenButton');
            // Recupera do navegador se o Modo TV estava ativo na ultima interacao.
            let enabled = localStorage.getItem('bullpace-tv-active') !== 'false';

            // Aplica visualmente o estado atual do Modo TV.
            const updateState = () => {
              // Marca o card como ativo quando o placar deve aparecer.
              card.classList.toggle('is-active', enabled);
              // Marca o card como inativo quando o placar deve ficar pausado.
              card.classList.toggle('is-inactive', !enabled);
              // Atualiza atributo de acessibilidade do botao.
              toggle.setAttribute('aria-pressed', String(enabled));
              // Atualiza o texto do selo.
              label.textContent = enabled ? 'ATIVO' : 'INATIVO';
              // Mostra o link como indisponivel quando o modo esta inativo.
              externalButton.classList.toggle('is-disabled', !enabled);
              // Informa leitores de tela sobre o estado do link.
              externalButton.setAttribute('aria-disabled', String(!enabled));
              // Troca a chamada principal conforme o estado.
              externalButton.textContent = enabled ? 'Abrir tela externa' : 'Ative o Modo TV para abrir';
              // Salva o estado no navegador para a tela /tv conseguir ler.
              localStorage.setItem('bullpace-tv-active', enabled ? 'true' : 'false');
            };

            // Ao clicar na chave, inverte ativo/inativo.
            toggle.addEventListener('click', () => {
              enabled = !enabled;
              updateState();
            });

            // Impede abrir a TV externa quando o modo esta inativo.
            externalButton.addEventListener('click', (event) => {
              if (!enabled) {
                event.preventDefault();
              }
            });

            // Inicializa a tela with o estado salvo.
            updateState();
          })();
        </script>
      <% } %>

      <% if (tela === 'tvPublica') { %>
        <% /* Nota: placar publico para TV/projetor. */ %>
        <section class="tv-scoreboard">
          <header class="tv-header">
            <div>
              <strong>BULLPACE</strong>
              <span>PLACAR AO VIVO</span>
            </div>
            <em>AO VIVO</em>
          </header>

          <section class="tv-event">
            <h1>24 HORAS</h1>
            <p>08h 42min de prova · 15h 18min restantes</p>
          </section>

          <section class="tv-paused-message">
            <strong>PLACAR PAUSADO</strong>
            <span>Os dados públicos foram ocultados pela coordenação.</span>
          </section>

          <section class="tv-ranking">
            <article>
              <span>EQUIPE</span>
              <strong>Equipe Vermelha</strong>
              <p>124,480 <small>km</small></p>
            </article>
            <article>
              <span>EQUIPE</span>
              <strong>Equipe Azul</strong>
              <p>121,930 <small>km</small></p>
            </article>
          </section>

          <section class="tv-difference">
            <strong>DIFERENÇA</strong>
            <span>+ 2,550 km</span>
          </section>

          <footer>Visualização pública · sem comandos operacionais</footer>
        </section>

        <script>
          (() => {
            // Busca o placar publico renderizado na pagina /tv.
            const scoreboard = document.querySelector('.tv-scoreboard');
            // Busca o selo de status do cabecalho da TV.
            const statusLabel = scoreboard.querySelector('.tv-header em');

            // Aplica na TV o estado salvo pelo controle do Modo TV.
            const applyTvState = () => {
              // Quando o valor salvo for "false", a TV deve ocultar os dados.
              const active = localStorage.getItem('bullpace-tv-active') !== 'false';
              // Classe usada no CSS para mostrar ou esconder o placar.
              scoreboard.classList.toggle('is-paused', !active);
              // Atualiza o texto do selo da TV.
              statusLabel.textContent = active ? 'AO VIVO' : 'PAUSADO';
            };

            // Escuta mudancas vindas de outra aba/janela do mesmo navegador.
            window.addEventListener('storage', applyTvState);
            // Aplica o estado assim que a TV abre.
            applyTvState();
          })();
        </script>
      <% } %>

      <% if (tela === 'tvResultado') { %>
        <% /* Nota: placar publico final para divulgar a equipe vencedora. */ %>
        <section class="tv-scoreboard tv-final-scoreboard">
          <header class="tv-header">
            <div>
              <strong>BULLPACE</strong>
              <span>RESULTADO OFICIAL</span>
            </div>
            <em>FINALIZADO</em>
          </header>

          <section class="tv-event">
            <h1>24 HORAS</h1>
            <p>Prova encerrada · resultado oficial</p>
          </section>

          <section class="tv-ranking">
            <% rankingFechamento.forEach((equipe) => { %>
              <article class="<%= equipe.posicao === 1 ? 'is-winner' : '' %>">
                <span><%= equipe.posicao %>º LUGAR</span>
                <strong><%= equipe.nome %></strong>
                <p><%= equipe.km.replace(' km', '') %> <small>km</small></p>
              </article>
            <% }) %>
          </section>

          <section class="tv-difference">
            <strong>DIFERENÇA</strong>
            <span><%= resultadoOficial.diferenca %></span>
          </section>

          <footer>Resultado publicado · somente leitura</footer>
        </section>
      <% } %>

      <% if (tela === 'fechamento') { %>
        <% /* Nota: revisao consolidada antes de encerrar oficialmente a prova. */ %>
        <p class="operator-description">
          Valide os dados antes de finalizar a prova.
        </p>

        <span class="closure-status">PRONTO PARA REVISÃO</span>

        <% if (typeof fechamentoMensagem !== 'undefined') { %>
          <p class="checkpoint-message success closure-message"><%= fechamentoMensagem %></p>
        <% } %>

        <p class="closure-section-title">Ranking consolidado</p>

        <section class="closure-ranking" aria-label="Ranking consolidado">
          <% rankingFechamento.forEach((equipe) => { %>
            <article class="closure-team-card <%= equipe.posicao === 1 ? 'is-first' : 'is-second' %>">
              <div>
                <strong><%= equipe.posicao %> <%= equipe.nome %></strong>
                <small><%= equipe.checkpoints %> checkpoints · <%= equipe.correcoes %> <%= equipe.correcoes === 1 ? 'correção' : 'correções' %></small>
              </div>
              <span><%= equipe.km %></span>
            </article>
          <% }) %>
        </section>

        <section class="closure-warning">
          <strong>A finalização bloqueia novos registros.</strong>
          <span>Revise antes de confirmar.</span>
        </section>

        <form action="/finalizar-prova" method="post" class="continue-form closure-action-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="continue-button">
            Finalizar prova
          </button>
        </form>

        <form action="/voltar-painel-coordenador" method="post" class="continue-form secondary-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="finish-button">
            Voltar ao painel
          </button>
        </form>
      <% } %>

      <% if (tela === 'confirmacaoFechamento') { %>
        <% /* Nota: confirmacao obrigatoria antes de tornar o resultado oficial. */ %>
        <p class="operator-description">
          Revise o bloqueio antes de concluir.
        </p>

        <span class="sensitive-status">AÇÃO SENSÍVEL</span>

        <section class="closure-warning confirmation-warning">
          <strong>Ao finalizar a prova:</strong>
          <span>Novos checkpoints serão bloqueados e o resultado passará a ser oficial.</span>
        </section>

        <p class="closure-section-title">CONFIRMAÇÃO OBRIGATÓRIA</p>

        <form action="/confirmar-finalizacao" method="post" class="confirmation-form" id="finishConfirmationForm">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">

          <label class="confirmation-check-card" for="finishConfirmationCheck">
            <input id="finishConfirmationCheck" name="confirmaBloqueio" value="sim" type="checkbox">
            <span>Estou ciente de que novos registros serão bloqueados.</span>
          </label>

          <section class="responsible-card">
            <strong>Responsável pela validação:</strong>
            <span><%= coordenadorSelecionado || resultadoOficial.validadoPor %></span>
          </section>

          <% if (typeof confirmacaoMensagem !== 'undefined') { %>
            <p class="checkpoint-message success closure-message"><%= confirmacaoMensagem %></p>
          <% } %>

          <button type="submit" class="continue-button" id="finishConfirmationButton" disabled>
            Marque a confirmação para continuar
          </button>
        </form>

        <form action="/voltar-fechamento" method="post" class="continue-form secondary-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="finish-button">
            Cancelar
          </button>
        </form>

        <script>
          (() => {
            const check = document.getElementById('finishConfirmationCheck');
            const button = document.getElementById('finishConfirmationButton');

            const updateButton = () => {
              button.disabled = !check.checked;
              button.textContent = check.checked ? 'Confirmar encerramento' : 'Marque a confirmação para continuar';
            };

            check.addEventListener('change', updateButton);
            updateButton();
          })();
        </script>
      <% } %>

      <% if (tela === 'resultadoOficial') { %>
        <% /* Nota: resultado oficial pronto para exportacao e publicacao na TV. */ %>
        <p class="operator-description">
          Dados encerrados e disponíveis para divulgação.
        </p>

        <span class="result-status">FINALIZADO</span>

        <p class="operator-list-title">EQUIPE VENCEDORA</p>

        <section class="result-winner-card">
          <div>
            <strong><%= resultadoOficial.vencedor.nome %></strong>
            <span><%= resultadoOficial.vencedor.km %></span>
          </div>
          <small>VENCEDORA</small>
        </section>

        <p class="operator-list-title">CONSOLIDADO</p>

        <section class="result-summary-list" aria-label="Dados consolidados">
          <article>
            <span>Total de checkpoints</span>
            <strong><%= resultadoOficial.totalCheckpoints %></strong>
          </article>
          <article>
            <span>Correções auditadas</span>
            <strong><%= resultadoOficial.correcoesAuditadas %></strong>
          </article>
          <article>
            <span>Resultado validado por</span>
            <strong><%= resultadoOficial.validadoPor %></strong>
          </article>
        </section>

        <a href="/exportar-dados?perfilUsuario=<%= perfilUsuario %>" class="continue-button result-action-button">
          Exportar CSV
        </a>

        <form action="/publicar-resultado" method="post" class="continue-form secondary-form result-publish-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="finish-button result-tv-link">
            Publicar no Modo TV
          </button>
        </form>
      <% } %>

      <% if (tela === 'publicarResultado') { %>
        <% /* Nota: confirmacao antes de liberar o placar final para o publico. */ %>
        <p class="operator-description">
          Confirme a exibição no placar público.
        </p>

        <section class="publish-result-card">
          <strong>RESULTADO OFICIAL</strong>
          <span><%= resultadoOficial.vencedor.nome %> · <%= resultadoOficial.vencedor.km %></span>
        </section>

        <section class="responsible-card publication-info-card">
          <strong>A publicação exibirá:</strong>
          <span>Ranking final, distância oficial e equipe vencedora. A tela pública continuará somente leitura.</span>
        </section>

        <section class="closure-warning publication-warning">
          <strong>Publicação visível ao público do evento.</strong>
        </section>

        <form action="/confirmar-publicacao" method="post" class="continue-form closure-action-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="continue-button">
            Confirmar publicação
          </button>
        </form>

        <form action="/voltar-resultado-oficial" method="post" class="continue-form secondary-form">
          <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
          <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
          <button type="submit" class="finish-button">
            Cancelar
          </button>
        </form>
      <% } %>

      <% if (tela === 'detalheEquipe') { %>
        <% /* Nota: detalhes de checkpoints da equipe selecionada. */ %>
        <p class="operator-description">
          Consulte registros gerais ou filtre por atleta.
        </p>

        <section class="team-detail-summary">
          <span class="status-dot" aria-hidden="true"></span>
          <div>
            <strong><%= equipePainel.nome %></strong>
            <small><%= equipePainel.km %> acumulados</small>
          </div>
          <span>TURNO ATIVO</span>
        </section>

        <section class="detail-tabs">
          <button type="button" class="is-active">Todos os checkpoints</button>
          <form action="/filtro-atletas-equipe" method="post">
            <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
            <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
            <input type="hidden" name="equipe" value="<%= equipePainel.nome %>">
            <button type="submit">Por atleta</button>
          </form>
        </section>

        <p class="operator-list-title">CHECKPOINTS DA EQUIPE</p>
        <p class="detail-subtitle">REGISTROS RECENTES · TODOS OS ATLETAS</p>

        <div class="checkpoint-record checkpoint-record-header" aria-hidden="true">
          <span>HORÁRIO</span>
          <span>ATLETA</span>
          <span>KM</span>
          <span>OPERADOR(A)</span>
        </div>

        <div class="checkpoint-record-list" aria-label="Checkpoints da equipe">
          <% checkpoints.forEach((checkpoint) => { %>
            <article class="checkpoint-record">
              <span><%= checkpoint.horario %></span>
              <strong><%= checkpoint.atleta %></strong>
              <strong><%= checkpoint.km %></strong>
              <span><%= checkpoint.operador %></span>
            </article>
          <% }) %>
        </div>

        <button type="button" class="continue-button audit-button">
          Auditar registro selecionado
        </button>
      <% } %>

      <% if (tela === 'filtroAtletasEquipe') { %>
        <% /* Nota: filtro de atletas dentro dos detalhes da equipe. */ %>
        <p class="operator-description">
          Selecione quem deseja investigar.
        </p>

        <section class="team-filter-summary">
          <span class="status-dot" aria-hidden="true"></span>
          <strong><%= equipePainel.nome %></strong>
          <span><%= equipePainel.atletas %> atletas cadastrados</span>
        </section>

        <section class="detail-tabs">
          <form action="/detalhes-equipe" method="post">
            <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
            <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
            <input type="hidden" name="equipe" value="<%= equipePainel.nome %>">
            <button type="submit">Todos os checkpoints</button>
          </form>
          <button type="button" class="is-active">Por atleta</button>
        </section>

        <p class="operator-list-title">ATLETAS</p>

        <div class="filter-athlete-list" aria-label="Atletas da equipe">
          <% atletasFiltro.forEach((atleta) => { %>
            <% const atletaAtual = atletaSelecionado === atleta.nome; %>
            <form action="/filtro-atletas-equipe" method="post" class="function-form">
              <input type="hidden" name="coordenador" value="<%= coordenadorSelecionado %>">
              <input type="hidden" name="perfilUsuario" value="<%= perfilUsuario %>">
              <input type="hidden" name="equipe" value="<%= equipePainel.nome %>">
              <input type="hidden" name="atleta" value="<%= atleta.nome %>">
              <button type="submit" class="operator-row filter-athlete-row <%= atletaAtual ? 'is-selected' : '' %>">
                <span class="operator-photo" aria-hidden="true"><%= atleta.iniciais %></span>
                <span class="operator-name">
                  <%= atleta.nome %>
                  <small><%= atleta.status %></small>
                </span>
                <% if (atletaAtual) { %>
                  <span class="selected-badge">ABRIR</span>
                <% } %>
              </button>
            </form>
          <% }) %>
        </div>

        <% if (typeof atletaSelecionado !== 'undefined') { %>
          <button type="button" class="continue-button audit-button">
            Ver histórico de <%= atletaSelecionado %>
          </button>
        <% } %>
      <% } %>

      <% if (tela === 'equipe') { %>
        <% /* Nota: bloco responsavel pela selecao da equipe acompanhada pelo operador. */ %>
        <p class="operator-description">
          Escolha a equipe que será acompanhada nesta etapa.
        </p>

        <p class="operator-list-title">EQUIPES CADASTRADAS</p>

        <div class="operator-list" aria-label="Seleção de equipe">
          <% equipes.forEach((equipe) => { %>
            <% const equipeAtual = typeof equipeSelecionada !== 'undefined' && equipeSelecionada === equipe.nome; %>
            <form action="/selecionar-equipe" method="post" class="function-form">
              <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
              <input type="hidden" name="equipe" value="<%= equipe.nome %>">
              <button type="submit" class="operator-row <%= equipeAtual ? 'is-selected' : '' %>">
                <span class="operator-photo" aria-hidden="true"><%= equipe.iniciais %></span>
                <span class="operator-name">
                  <%= equipe.nome %>
                  <small><%= equipe.atletas %> atletas</small>
                </span>
                <% if (equipeAtual) { %>
                  <span class="selected-badge">SELECIONADO</span>
                <% } %>
                <span class="operator-radio" aria-hidden="true"></span>
              </button>
            </form>
          <% }) %>
        </div>

        <% if (typeof equipeSelecionada !== 'undefined') { %>
          <% /* Avanca para a tela de selecao de atletas da equipe. */ %>
          <form action="/continuar-equipe" method="post" class="continue-form">
            <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
            <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
            <button type="submit" class="continue-button">
              Continuar com <%= equipeSelecionada %>
            </button>
          </form>
          <p class="operator-helper">A equipe selecionada ficará vinculada ao operador.</p>
        <% } %>
      <% } %>

      <% if (tela === 'atleta') { %>
        <% /* Nota: tela operacional para escolher o atleta do proximo turno. */ %>
        <p class="operator-description">
          Selecione o atleta para iniciar o turno.
        </p>

        <section class="team-status">
          <span class="status-dot"></span>
          <strong><%= equipeSelecionada %></strong>
          <small>Próximo turno</small>
        </section>

        <p class="operator-list-title">ATLETAS DISPONÍVEIS</p>

        <% if (typeof ultimoAtleta !== 'undefined') { %>
          <p class="rotation-warning">
            <strong><%= ultimoAtleta %></strong> correu no último turno e não pode ser selecionado agora.
          </p>
        <% } %>

        <div class="athlete-scroll" aria-label="Lista de atletas">
          <% atletas.forEach((atleta) => { %>
            <% const atletaAtual = typeof atletaSelecionado !== 'undefined' && atletaSelecionado === atleta.nome; %>
            <% const atletaBloqueado = typeof ultimoAtleta !== 'undefined' && ultimoAtleta === atleta.nome; %>
            <form action="/selecionar-atleta" method="post" class="function-form">
              <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
              <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
              <input type="hidden" name="atleta" value="<%= atleta.nome %>">
              <% if (typeof ultimoAtleta !== 'undefined') { %>
                <input type="hidden" name="ultimoAtleta" value="<%= ultimoAtleta %>">
              <% } %>
              <button type="submit" class="operator-row athlete-row <%= atletaAtual ? 'is-selected' : '' %> <%= atletaBloqueado ? 'is-disabled' : '' %>" <%= atletaBloqueado ? 'disabled' : '' %>>
                <span class="operator-photo" aria-hidden="true"><%= atleta.iniciais %></span>
                <span class="operator-name">
                  <%= atleta.nome %>
                  <small><%= atletaBloqueado ? 'Indisponível: correu no último turno' : atleta.status %></small>
                </span>
                <% if (atletaAtual) { %>
                  <span class="selected-badge">SELECIONADO</span>
                <% } else if (atletaBloqueado) { %>
                  <span class="selected-badge">BLOQUEADO</span>
                <% } %>
                <span class="operator-radio" aria-hidden="true"></span>
              </button>
            </form>
          <% }) %>
        </div>

        <% if (typeof atletaSelecionado !== 'undefined') { %>
          <% /* Avanca para a tela onde a esteira do turno sera definida. */ %>
          <form action="/continuar-atleta" method="post" class="continue-form">
            <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
            <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
            <input type="hidden" name="atleta" value="<%= atletaSelecionado %>">
            <% if (typeof ultimoAtleta !== 'undefined') { %>
              <input type="hidden" name="ultimoAtleta" value="<%= ultimoAtleta %>">
            <% } %>
            <button type="submit" class="continue-button">
              Continuar com <%= atletaSelecionado %>
            </button>
          </form>
          <p class="operator-helper">A próxima etapa será a definição da esteira.</p>
        <% } %>
      <% } %>

      <% if (tela === 'esteira') { %>
        <% /* Nota: tela responsavel por confirmar o atleta e selecionar a esteira do turno. */ %>
        <p class="operator-description">
          Confirme atleta e esteira antes de registrar o início.
        </p>

        <p class="operator-list-title">RESUMO DO TURNO</p>

        <section class="turn-summary">
          <span class="operator-photo summary-photo" aria-hidden="true">
            <%= atletaSelecionado.split(' ').map((parte) => parte[0]).join('').slice(0, 2) %>
          </span>
          <div class="summary-content">
            <strong><%= atletaSelecionado %></strong>
            <span><%= equipeSelecionada %></span>
          </div>
          <small>
            <%= typeof esteiraSelecionada !== 'undefined' ? esteiraSelecionada : 'Esteira a confirmar' %>
          </small>
        </section>

        <p class="operator-list-title">SELECIONE A ESTEIRA</p>

        <div class="operator-list treadmill-list" aria-label="Seleção de esteira">
          <% esteiras.forEach((esteira) => { %>
            <% const esteiraAtual = typeof esteiraSelecionada !== 'undefined' && esteiraSelecionada === esteira.nome; %>
            <% const emManutencao = esteira.tipo !== 'livre'; %>
            <form action="/selecionar-esteira" method="post" class="function-form <%= emManutencao ? 'maintenance-bypass-form' : '' %>" data-treadmill-name="<%= esteira.nome %>">
              <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
              <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
              <input type="hidden" name="atleta" value="<%= atletaSelecionado %>">
              <input type="hidden" name="esteira" value="<%= esteira.nome %>">
              <% if (emManutencao) { %>
                <input type="hidden" name="bypassManutencao" value="sim">
              <% } %>
              <button type="submit" class="operator-row treadmill-row <%= esteiraAtual ? 'is-selected' : '' %> <%= emManutencao ? 'is-maintenance-bypass' : '' %>">
                <span class="status-dot <%= emManutencao ? 'muted-dot' : '' %>" aria-hidden="true"></span>
                <span class="operator-name">
                  <%= esteira.nome %>
                  <small><%= esteira.status %></small>
                </span>
                <% if (esteiraAtual) { %>
                  <span class="selected-badge">SELECIONADO</span>
                <% } %>
                <span class="operator-radio" aria-hidden="true"></span>
              </button>
            </form>
          <% }) %>
        </div>

        <% if (typeof esteiraEmManutencaoSelecionada !== 'undefined' && esteiraEmManutencaoSelecionada) { %>
          <p class="turn-note maintenance-bypass-note">
            Você está utilizando uma esteira em manutenção e confirmou que está de acordo.
          </p>
        <% } %>

        <p class="turn-note">O horário de início será salvo automaticamente.</p>

        <% if (typeof esteiraSelecionada !== 'undefined') { %>
          <% /* Inicia o turno e abre a tela de checkpoint. */ %>
          <form action="/iniciar-turno" method="post" class="continue-form">
            <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
            <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
            <input type="hidden" name="atleta" value="<%= atletaSelecionado %>">
            <input type="hidden" name="esteira" value="<%= esteiraSelecionada %>">
            <% if (typeof esteiraEmManutencaoSelecionada !== 'undefined' && esteiraEmManutencaoSelecionada) { %>
              <input type="hidden" name="bypassManutencao" value="sim">
            <% } %>
            <button type="submit" class="continue-button">
              Iniciar turno na <%= esteiraSelecionada %>
            </button>
          </form>
        <% } %>

        <div id="maintenanceBypassModal" class="modal-overlay" hidden>
          <section class="modal-box maintenance-bypass-modal" role="dialog" aria-modal="true" aria-labelledby="maintenanceBypassTitle">
            <h2 id="maintenanceBypassTitle">Esteira em manutenção</h2>
            <p>
              Você está selecionando a <strong id="maintenanceBypassName">esteira</strong>, marcada como em manutenção.
              Confirme que está de acordo para usar este bypass.
            </p>
            <div class="modal-actions">
              <button id="cancelMaintenanceBypass" type="button" class="modal-secondary-button">Cancelar</button>
              <button id="confirmMaintenanceBypass" type="button">Estou de acordo</button>
            </div>
          </section>
        </div>

        <script>
          (() => {
            const modal = document.getElementById('maintenanceBypassModal');
            const treadmillName = document.getElementById('maintenanceBypassName');
            const cancelButton = document.getElementById('cancelMaintenanceBypass');
            const confirmButton = document.getElementById('confirmMaintenanceBypass');
            let pendingForm = null;

            document.querySelectorAll('.maintenance-bypass-form').forEach((form) => {
              form.addEventListener('submit', (event) => {
                if (form.dataset.bypassConfirmed === 'true') {
                  return;
                }

                event.preventDefault();
                pendingForm = form;
                treadmillName.textContent = form.dataset.treadmillName || 'esteira';
                modal.hidden = false;
                confirmButton.focus();
              });
            });

            const closeModal = () => {
              modal.hidden = true;
              pendingForm = null;
            };

            cancelButton.addEventListener('click', closeModal);

            confirmButton.addEventListener('click', () => {
              if (!pendingForm) {
                closeModal();
                return;
              }

              pendingForm.dataset.bypassConfirmed = 'true';
              pendingForm.submit();
            });
          })();
        </script>
      <% } %>

      <% if (tela === 'checkpoint') { %>
        <% /* Nota: tela usada para registrar checkpoints durante o turno ativo. */ %>
        <p class="flow-context">Turno em andamento</p>

        <section class="active-turn-card">
          <span class="operator-photo active-athlete-photo" aria-hidden="true">
            <%= atletaSelecionado.split(' ').map((parte) => parte[0]).join('').slice(0, 2) %>
          </span>
          <div>
            <strong><%= atletaSelecionado %></strong>
            <span><%= esteiraSelecionada %> · <%= equipeSelecionada %></span>
            <time id="turnTimer">00:00:00</time>
          </div>
          <small>EM CORRIDA</small>
        </section>

        <form id="checkpointForm" class="checkpoint-form" novalidate>
          <section class="athlete-checkpoint-summary" aria-label="Resumo de checkpoints do atleta ativo">
            <article>
              <span>KM TOTAL DO ATLETA</span>
              <strong><span id="athleteTotalKm">0,000</span> km</strong>
            </article>
            <article>
              <span>ÚLTIMO CHECKPOINT</span>
              <strong id="athleteLastCheckpoint">Nenhum registro</strong>
            </article>
            <article>
              <span>PRÓXIMO CHECKPOINT</span>
              <strong id="nextCheckpointTimer">Disponível agora</strong>
            </article>
          </section>

          <label class="field-label" for="kmAcumulado">KM ACUMULADO *</label>
          <div class="input-with-unit">
            <input id="kmAcumulado" name="kmAcumulado" class="checkpoint-input" type="text" inputmode="decimal" placeholder="12,480" required>
            <span>km</span>
          </div>

          <section class="last-checkpoint">
            <div>
              <strong>ÚLTIMO CHECKPOINT</strong>
              <span id="lastCheckpointText">Nenhum checkpoint registrado</span>
            </div>
            <small id="checkpointStatus">AGUARDANDO</small>
          </section>

          <p id="checkpointMessage" class="checkpoint-message" hidden></p>

          <button id="registerCheckpointButton" type="submit" class="continue-button checkpoint-button">
            Registrar checkpoint
          </button>
        </form>

        <% /* Abre a etapa de encerramento com o resumo do turno atual. */ %>
        <form id="finishTurnForm" action="/finalizar-turno" method="post" class="finish-form">
          <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
          <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
          <input type="hidden" name="atleta" value="<%= atletaSelecionado %>">
          <input type="hidden" name="esteira" value="<%= esteiraSelecionada %>">
          <input id="finishKmFinal" type="hidden" name="kmFinal" value="">
          <input id="finishDuracaoTurno" type="hidden" name="duracaoTurno" value="00:00:00">
          <input id="finishInicioTurnoTimestamp" type="hidden" name="inicioTurnoTimestamp" value="<%= inicioTurnoTimestamp %>">
          <input id="finishIdTurno" type="hidden" name="idTurno" value="<%= typeof idTurno !== 'undefined' ? idTurno : '' %>">
          <button type="submit" class="finish-button">Finalizar turno</button>
        </form>

        <div id="checkpointModal" class="modal-overlay" hidden>
          <section class="modal-box" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
            <h2 id="modalTitle">Checkpoint registrado</h2>
            <p>O registro foi salvo. O próximo checkpoint será liberado em 5 minutos.</p>
            <button id="closeCheckpointModal" type="button">OK</button>
          </section>
        </div>

        <script>
          (() => {
            // Busca o formulario de checkpoint.
            const form = document.getElementById('checkpointForm');
            // Busca o botao principal de registrar checkpoint.
            const button = document.getElementById('registerCheckpointButton');
            // Busca a area onde aparecem mensagens de erro ou sucesso.
            const message = document.getElementById('checkpointMessage');
            // Busca o texto que mostra o ultimo checkpoint salvo.
            const lastCheckpointText = document.getElementById('lastCheckpointText');
            // Busca o selo de status do ultimo checkpoint.
            const checkpointStatus = document.getElementById('checkpointStatus');
            // Busca os indicadores consolidados do atleta ativo.
            const athleteTotalKm = document.getElementById('athleteTotalKm');
            const athleteLastCheckpoint = document.getElementById('athleteLastCheckpoint');
            const nextCheckpointTimer = document.getElementById('nextCheckpointTimer');
            // Busca o modal exibido depois de registrar.
            const modal = document.getElementById('checkpointModal');
            // Busca o botao que fecha o modal.
            const closeModal = document.getElementById('closeCheckpointModal');
            // Busca o relogio do turno ativo.
            const turnTimer = document.getElementById('turnTimer');
            // Busca o formulario que finaliza o turno.
            const finishForm = document.getElementById('finishTurnForm');
            // Campo escondido que leva o km final para o servidor.
            const finishKmFinal = document.getElementById('finishKmFinal');
            // Campo escondido que leva a duracao do turno para o servidor.
            const finishDuracaoTurno = document.getElementById('finishDuracaoTurno');
            // Campo escondido que preserva o horario de inicio entre telas.
            const finishInicioTurnoTimestamp = document.getElementById('finishInicioTurnoTimestamp');
            // Define o intervalo de 5 minutos entre checkpoints.
            const cooldownMilliseconds = 5 * 60 * 1000;
            // Guarda o id do intervalo que atualiza o contador do botao.
            let cooldownInterval;
            // Guarda o horario real em que o turno comecou.
            const pageParams = new URLSearchParams(window.location.search);
            const turnStartedAt = Number(pageParams.get('inicioTurnoTimestamp') || '<%= inicioTurnoTimestamp %>') || Date.now();
            finishInicioTurnoTimestamp.value = String(turnStartedAt);
            // Identifica os checkpoints do atleta ativo no armazenamento local da tela.
            const activeAthleteKey = [
              'checkpoints',
              '<%= equipeSelecionada %>',
              '<%= atletaSelecionado %>'
            ].join(':');
            // Lista em memoria dos checkpoints vinculados ao atleta ativo.
            let athleteCheckpoints = [];

            // Formata segundos no padrao HH:MM:SS.
            const formatTime = (seconds) => {
              const hours = String(Math.floor(seconds / 3600)).padStart(2, '0');
              const minutes = String(Math.floor((seconds % 3600) / 60)).padStart(2, '0');
              const remainingSeconds = String(seconds % 60).padStart(2, '0');
              return `${hours}:${minutes}:${remainingSeconds}`;
            };

            // Converte a quilometragem informada em numero, aceitando virgula decimal.
            const parseKilometers = (value) => {
              const normalizedValue = String(value)
                .trim()
                .replace(/\./g, '')
                .replace(',', '.');
              const kilometers = Number(normalizedValue);
              return Number.isFinite(kilometers) ? kilometers : 0;
            };

            // Formata quilometragem no padrao visual usado pela aplicacao.
            const formatKilometers = (value) => value.toLocaleString('pt-BR', {
              minimumFractionDigits: 3,
              maximumFractionDigits: 3
            });

            // Formata data e hora do checkpoint mais recente.
            const formatCheckpointDate = (timestamp) => new Date(timestamp).toLocaleString('pt-BR', {
              day: '2-digit',
              month: '2-digit',
              year: '2-digit',
              hour: '2-digit',
              minute: '2-digit',
              second: '2-digit'
            });

            // Carrega registros anteriores do atleta ativo quando existirem.
            const loadAthleteCheckpoints = () => {
              try {
                const storedCheckpoints = JSON.parse(localStorage.getItem(activeAthleteKey) || '[]');
                athleteCheckpoints = Array.isArray(storedCheckpoints) ? storedCheckpoints : [];
              } catch (error) {
                athleteCheckpoints = [];
              }
            };

            // Persiste a lista atualizada para manter o vinculo com o atleta ativo.
            const saveAthleteCheckpoints = () => {
              localStorage.setItem(activeAthleteKey, JSON.stringify(athleteCheckpoints));
            };

            // Atualiza KM total do atleta, ultimo checkpoint e valor levado ao encerramento.
            const updateAthleteCheckpointSummary = () => {
              const totalKm = athleteCheckpoints.reduce((total, checkpoint) => total + checkpoint.km, 0);
              const lastCheckpoint = athleteCheckpoints
                .slice()
                .sort((a, b) => b.registeredAt - a.registeredAt)[0];

              athleteTotalKm.textContent = formatKilometers(totalKm);

              if (!lastCheckpoint) {
                athleteLastCheckpoint.textContent = 'Nenhum registro';
                lastCheckpointText.textContent = 'Nenhum checkpoint registrado';
                checkpointStatus.textContent = 'AGUARDANDO';
                finishKmFinal.value = '';
                return;
              }

              const formattedDate = formatCheckpointDate(lastCheckpoint.registeredAt);
              athleteLastCheckpoint.textContent = formattedDate;
              lastCheckpointText.textContent = `${formatKilometers(lastCheckpoint.km)} km · ${formattedDate}`;
              finishKmFinal.value = lastCheckpoint.rawKm;
              checkpointStatus.textContent = 'SALVO';
            };

            // Calcula quanto falta para o proximo checkpoint obrigatorio.
            const updateNextCheckpointTimer = (availableAt = Date.now()) => {
              const remaining = Math.max(0, availableAt - Date.now());
              const minutes = String(Math.floor(remaining / 60000)).padStart(2, '0');
              const seconds = String(Math.floor((remaining % 60000) / 1000)).padStart(2, '0');

              nextCheckpointTimer.textContent = remaining > 0 ? `${minutes}:${seconds}` : 'Disponível agora';
              button.textContent = remaining > 0 ? `Novo checkpoint em ${minutes}:${seconds}` : 'Registrar novo checkpoint';

              return remaining;
            };

            // Atualiza o relogio do turno com base no horario real de inicio.
            const updateTurnTimer = () => {
              const turnSeconds = Math.max(0, Math.floor((Date.now() - turnStartedAt) / 1000));
              turnTimer.textContent = formatTime(turnSeconds);
              finishDuracaoTurno.value = turnTimer.textContent;
            };

            loadAthleteCheckpoints();
            updateAthleteCheckpointSummary();
            updateTurnTimer();
            setInterval(updateTurnTimer, 1000);

            // Mostra uma mensagem padronizada abaixo do ultimo checkpoint.
            const showMessage = (text, type) => {
              message.textContent = text;
              message.className = `checkpoint-message ${type}`;
              message.hidden = false;
            };

            // Bloqueia o botao por 5 minutos depois de um checkpoint.
            const startCooldown = () => {
              // Calcula o horario em que o botao sera liberado novamente.
              const availableAt = Date.now() + cooldownMilliseconds;
              button.disabled = true;
              clearInterval(cooldownInterval);
              updateNextCheckpointTimer(availableAt);

              // Atualiza o texto do botao varias vezes por segundo.
              cooldownInterval = setInterval(() => {
                const remaining = updateNextCheckpointTimer(availableAt);

                // Quando o tempo acaba, libera o botao e para o intervalo.
                if (remaining <= 0) {
                  clearInterval(cooldownInterval);
                  button.disabled = false;
                }
              }, 250);
            };

            // Intercepta o envio do formulario para validar e salvar no banco.
            form.addEventListener('submit', async (event) => {
              // Evita recarregar a pagina ao registrar checkpoint.
              event.preventDefault();
              // Busca todos os campos obrigatorios do formulario.
              const requiredFields = Array.from(form.querySelectorAll('[required]'));
              // Filtra campos obrigatorios que ainda estao vazios.
              const missingFields = requiredFields.filter((field) => !field.value.trim());

              // Se houver campo vazio, foca no primeiro e mostra erro.
              if (missingFields.length > 0) {
                missingFields[0].focus();
                showMessage('Preencha todos os campos obrigatórios antes de registrar.', 'error');
                return;
              }

              // Le a quilometragem informada.
              const km = document.getElementById('kmAcumulado').value.trim();
              const checkpointTimestamp = Date.now();

              try {
                const response = await fetch('/registrar-checkpoint', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    operador: '<%= operadorSelecionado %>',
                    equipe: '<%= equipeSelecionada %>',
                    atleta: '<%= atletaSelecionado %>',
                    esteira: '<%= esteiraSelecionada %>',
                    kmAcumulado: km,
                    inicioTurnoTimestamp: turnStartedAt,
                    idTurno: window.idTurno || '<%= typeof idTurno !== "undefined" ? idTurno : "" %>'
                  })
                });
                const resData = await response.json();
                if (!response.ok) {
                  throw new Error(resData.error || 'Erro ao registrar checkpoint.');
                }
                if (resData.idTurno) {
                  window.idTurno = resData.idTurno;
                  const hiddenIdTurno = document.getElementById('finishIdTurno');
                  if (hiddenIdTurno) {
                    hiddenIdTurno.value = String(resData.idTurno);
                  }
                }
                
                athleteCheckpoints.push({
                  atleta: '<%= atletaSelecionado %>',
                  equipe: '<%= equipeSelecionada %>',
                  km: parseKilometers(km),
                  rawKm: km,
                  registeredAt: checkpointTimestamp
                });
                saveAthleteCheckpoints();
                updateAthleteCheckpointSummary();
                showMessage('Checkpoint registrado com sucesso.', 'success');
                modal.hidden = false;
                startCooldown();
              } catch (err) {
                showMessage('Erro ao salvar no banco: ' + err.message, 'error');
              }
            });

            // Fecha o modal quando o operador clica em OK.
            closeModal.addEventListener('click', () => {
              modal.hidden = true;
            });

            // Antes de encerrar o turno, garante que existe km final informado.
            finishForm.addEventListener('submit', (event) => {
              // Le a quilometragem final do campo visivel.
              const km = document.getElementById('kmAcumulado').value.trim();

              // Bloqueia encerramento sem quilometragem.
              if (!km) {
                event.preventDefault();
                document.getElementById('kmAcumulado').focus();
                showMessage('Informe a quilometragem final antes de encerrar o turno.', 'error');
                return;
              }

              // Envia o km final pelo campo escondido.
              finishKmFinal.value = km;
              // Envia a duracao atual do turno pelo campo escondido.
              finishDuracaoTurno.value = turnTimer.textContent;
            });
          })();
        </script>
      <% } %>

      <% if (tela === 'encerramento') { %>
        <% /* Nota: tela de conferencia antes de encerrar o turno e voltar para os atletas. */ %>
        <p class="operator-description">
          Confira o atleta e os dados antes de encerrar.
        </p>

        <p class="turn-note end-warning">Confirme a quilometragem final registrada.</p>

        <section class="turn-summary end-athlete-summary">
          <span class="operator-photo summary-photo" aria-hidden="true">
            <%= atletaSelecionado.split(' ').map((parte) => parte[0]).join('').slice(0, 2) %>
          </span>
          <div class="summary-content">
            <strong><%= atletaSelecionado %></strong>
            <span><%= esteiraSelecionada %> · <%= equipeSelecionada %></span>
          </div>
          <small>ATLETA</small>
        </section>

        <section class="end-metrics" aria-label="Resumo do turno">
          <article>
            <strong>INÍCIO</strong>
            <span><%= inicioTurno %></span>
          </article>
          <article>
            <strong>DURAÇÃO</strong>
            <span><%= duracaoTurno %></span>
          </article>
          <article>
            <strong>KM FINAL</strong>
            <span><%= kmFinal %> km</span>
          </article>
        </section>

        <section class="after-confirm">
          <strong>APÓS CONFIRMAR</strong>
          <span>Checkpoint final salvo</span>
          <span>Esteira liberada para o próximo atleta</span>
          <span>Histórico preservado</span>
        </section>

        <div class="modal-overlay final-check-modal">
          <section class="modal-box final-check-box" role="dialog" aria-modal="true" aria-labelledby="finalCheckTitle" aria-describedby="finalCheckDescription">
            <p class="final-check-kicker">Verificação final</p>
            <h2 id="finalCheckTitle">Está tudo certo com o encerramento?</h2>
            <p id="finalCheckDescription">
              Confira o KM final da esteira e o tempo total corrido antes de liberar o próximo atleta.
            </p>

            <section class="final-check-athlete" aria-label="Atleta em encerramento">
              <span class="operator-photo summary-photo" aria-hidden="true">
                <%= atletaSelecionado.split(' ').map((parte) => parte[0]).join('').slice(0, 2) %>
              </span>
              <div>
                <strong><%= atletaSelecionado %></strong>
                <span><%= esteiraSelecionada %> · <%= equipeSelecionada %></span>
              </div>
            </section>

            <form action="/confirmar-encerramento" method="post" class="final-check-form">
              <input type="hidden" name="operador" value="<%= operadorSelecionado %>">
              <input type="hidden" name="equipe" value="<%= equipeSelecionada %>">
              <input type="hidden" name="atleta" value="<%= atletaSelecionado %>">
              <input type="hidden" name="perfilUsuario" value="operador">
              <input type="hidden" name="idTurno" value="<%= typeof idTurno !== 'undefined' && idTurno ? idTurno : '' %>">

              <section class="final-check-grid" aria-label="Dados finais do turno">
                <label>
                  <strong>KM FINAL DA ESTEIRA</strong>
                  <span class="final-check-input-wrap">
                    <input name="kmFinal" type="text" inputmode="decimal" value="<%= kmFinal %>" aria-label="KM final da esteira" required>
                    <small>km</small>
                  </span>
                </label>
                <label>
                  <strong>TEMPO TOTAL CORRIDO</strong>
                  <input name="duracaoTurno" type="text" inputmode="numeric" value="<%= duracaoTurno %>" aria-label="Tempo total corrido" placeholder="00:00:00" required>
                </label>
              </section>

              <div class="final-check-actions">
                <button type="submit" class="continue-button">
                  Confirmar encerramento
                </button>
              </div>
            </form>
          </section>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
